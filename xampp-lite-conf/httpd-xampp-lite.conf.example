# PHP-Module setup
#

# php 8 "Thread Safe"
<IfFile "${XAMPP_LITE_ROOT}/apps/php/php8apache2_4.dll">
    LoadModule php_module "${XAMPP_LITE_ROOT}/apps/php/php8apache2_4.dll"
    LoadFile "${XAMPP_LITE_ROOT}/apps/php/php8ts.dll"
</IfFile>

# php 7 "Thread Safe"
<IfFile "${XAMPP_LITE_ROOT}/apps/php/php7apache2_4.dll">
    LoadModule php7_module "${XAMPP_LITE_ROOT}/apps/php/php7apache2_4.dll"
    LoadFile "${XAMPP_LITE_ROOT}/apps/php/php7ts.dll"
</IfFile>

# php 5 "Thread Safe"
<IfFile "${XAMPP_LITE_ROOT}/apps/php/php5apache2_4.dll">
    LoadModule php5_module "${XAMPP_LITE_ROOT}/apps/php/php5apache2_4.dll"
    LoadFile "${XAMPP_LITE_ROOT}/apps/php/php5ts.dll"
</IfFile>

# PostgreSQL
<IfFile "${XAMPP_LITE_ROOT}/apps/php/libpq.dll">
    LoadFile "${XAMPP_LITE_ROOT}/apps/php/libpq.dll"
</IfFile>

# SQLite
<IfFile "${XAMPP_LITE_ROOT}/apps/php/libsqlite3.dll">
    LoadFile "${XAMPP_LITE_ROOT}/apps/php/libsqlite3.dll"
</IfFile>

# cURL

# Ensure to load libcrypto-*.dll and libssl-*.dll (previously known as libeay32.dll and ssleay32.dll) 
# libssh2.dll is also required.  The cURL library (libcurl.dll) is not needed.

<IfFile "${XAMPP_LITE_ROOT}/apps/php/libssh2.dll">
    LoadFile "${XAMPP_LITE_ROOT}/apps/php/libssh2.dll"
</IfFile>
# --
<IfFile "${XAMPP_LITE_ROOT}/apps/php/libcrypto-1_1.dll">
    LoadFile "${XAMPP_LITE_ROOT}/apps/php/libcrypto-1_1.dll"
</IfFile>
<IfFile "${XAMPP_LITE_ROOT}/apps/php/libcrypto-1_1-x64.dll">
    LoadFile "${XAMPP_LITE_ROOT}/apps/php/libcrypto-1_1-x64.dll"
</IfFile>
<IfFile "${XAMPP_LITE_ROOT}/apps/php/libcrypto-3.dll">
    LoadFile "${XAMPP_LITE_ROOT}/apps/php/libcrypto-3.dll"
</IfFile>
<IfFile "${XAMPP_LITE_ROOT}/apps/php/libcrypto-3-x64.dll">
    LoadFile "${XAMPP_LITE_ROOT}/apps/php/libcrypto-3-x64.dll"
</IfFile>
# -- 
<IfFile "${XAMPP_LITE_ROOT}/apps/php/libssl-1_1-x64.dll">
    LoadFile "${XAMPP_LITE_ROOT}/apps/php/libssl-1_1-x64.dll"
</IfFile>
<IfFile "${XAMPP_LITE_ROOT}/apps/php/libssl-1_1.dll">
    LoadFile "${XAMPP_LITE_ROOT}/apps/php/libssl-1_1.dll"
</IfFile>
<IfFile "${XAMPP_LITE_ROOT}/apps/php/libssl-3.dll">
    LoadFile "${XAMPP_LITE_ROOT}/apps/php/libssl-3.dll"
</IfFile>
<IfFile "${XAMPP_LITE_ROOT}/apps/php/libssl-3-x64.dll">
    LoadFile "${XAMPP_LITE_ROOT}/apps/php/libssl-3-x64.dll"
</IfFile>



