LoadFile "${XAMPP_LITE_ROOT}/apps/php/libsasl.dll"


<FilesMatch "\.php$">
    SetHandler application/x-httpd-php
</FilesMatch>

<FilesMatch "\.phps$">
    SetHandler application/x-httpd-php-source
</FilesMatch>

#
# PHP-CGI setup
#
#<FilesMatch "\.php$">
#    SetHandler application/x-httpd-php-cgi
#</FilesMatch>
#<IfModule actions_module>
#    Action application/x-httpd-php-cgi "/php-cgi/php-cgi.exe"
#</IfModule>


<IfModule php_module>
    PHPINIDir "${XAMPP_LITE_ROOT}/apps/php"
</IfModule>

<IfModule mime_module>
    AddType text/html .php .phps
</IfModule>

ScriptAlias /php-cgi/ "${XAMPP_LITE_ROOT}/apps/php/"
<Directory "${XAMPP_LITE_ROOT}/apps/php">
    AllowOverride None
    Options None
    Require all denied
    <Files "php-cgi.exe">
        Require all granted
    </Files>
</Directory>

<Directory "${XAMPP_LITE_ROOT}/apps/cgi-bin">
    <FilesMatch "\.php$">
        SetHandler cgi-script
    </FilesMatch>
    <FilesMatch "\.phps$">
        SetHandler None
    </FilesMatch>
</Directory>

# Disable caching
<IfModule headers_module>
    Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
    FileETag None
    Header unset ETag
    Header set Pragma "no-cache"
    Header set Expires "Fri, 14 Jan 2011 00:00:00 GMT"
</IfModule>

# Aliases — moved to conf/extra/httpd-xampp-lite-aliases.conf
# (included only in localhost VirtualHost; see httpd-vhosts.conf)
